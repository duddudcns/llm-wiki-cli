{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|mcp__llm-wiki__llmw_search|mcp__llm-wiki__llmw_write|mcp__llm-wiki__llmw_edit|mcp__llm-wiki__llmw_patch|mcp__llm-wiki__llmw_archive",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/pre-tool-use.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/stop.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
